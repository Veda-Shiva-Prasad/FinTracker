{
  "version": 2,
  "builds": [
    {
      "src": "backend1/api/index.js",
      "use": "@vercel/node",
      "config": {
        "nodeVersion": "18"
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend1/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
